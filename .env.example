# Copy to .env and fill in values before deploying
DATABASE_URL=postgresql://pypycode:CHANGE_ME@db:5432/pypycode
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME
SECRET_KEY=CHANGE_ME_USE_SECRETS_MANAGER
CELERY_BROKER_URL=redis://:REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REDIS_PASSWORD@redis:6379/2
POSTGRES_DB=pypycode
POSTGRES_USER=pypycode
POSTGRES_PASSWORD=CHANGE_ME
ALLOWED_ORIGINS=https://yourdomain.com
SANDBOX_IMAGE=pypycode-sandbox:latest

# Optional perf profile variables
APP_CONFIG=default
PERF_DATABASE_URL=postgresql://pypycode:CHANGE_ME@db_perf:5432/pypycode_perf
PERF_SQLALCHEMY_POOL_SIZE=20
PERF_SQLALCHEMY_MAX_OVERFLOW=40
